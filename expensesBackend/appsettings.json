{{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "FrontendUrl": "http://localhost:4200"
  },
  "ConnectionStrings": {
    "MongoDB": "mongodb://localhost:27017"
  },
  "MongoDB": {
    "DatabaseName": "ExpenseTrackerDB"
  },
  "Jwt": {
    "Secret": "your-super-secret-key-min-32-chars-long-for-production-change-this",
    "Issuer": "ExpensesBackend",
    "Audience": "ExpensesBackend",
    "ExpirationHours": 24
  },
  "Google": {
    "ClientId": "your-google-client-id",
    "ClientSecret": "your-google-client-secret"
  },
  "Redis": {
    "ConnectionString": "your-redis-connection-string",
    "InstanceName": "ExpenseTracker:"
  },
  "Messaging": {
    "Provider": "MSG91",
    "MSG91": {
      "AuthKey": "your-msg91-auth-key",
      "SmsTemplateId": "your-msg91-sms-template-id",
      "EmailTemplateId": "your-msg91-email-template-id",
      "EmailDomain": "your-domain.mailer91.com",
      "FromEmail": "noreply@your-domain.mailer91.com",
      "FromName": "Expense Tracker"
    },
    "Twilio": {
      "AccountSid": "your-twilio-account-sid",
      "AuthToken": "your-twilio-auth-token",
      "FromPhone": "+1XXXXXXXXXX"
    },
    "SendGrid": {
      "ApiKey": "your-sendgrid-api-key",
      "FromEmail": "noreply@yourdomain.com",
      "FromName": "Expense Tracker"
    }
  }
}
}